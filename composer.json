{
    "name": "jainamdeveloper/magento2-custom-redirect",
    "description": "Magento 2 module that recovers 404 visitors with intelligent 301 redirects. Disabled category redirects to nearest active parent, removed product redirects to active category. Full multi-store and multi-website support.",
    "type": "magento2-module",
    "license": "MIT",
    "homepage": "https://github.com/JainamDeveloper/magento2-custom-redirect",
    "keywords": [
        "magento2",
        "magento2-module",
        "magento2-extension",
        "magento2-redirect",
        "magento2-404",
        "magento2-seo",
        "301-redirect",
        "magento2-noroute",
        "magento2-category-redirect",
        "magento2-product-redirect"
    ],
    "authors": [
        {
            "name": "Jainam Shah",
            "email": "jainamshah2289@gmail.com",
            "homepage": "https://github.com/JainamDeveloper",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/JainamDeveloper/magento2-custom-redirect/issues",
        "source": "https://github.com/JainamDeveloper/magento2-custom-redirect"
    },
    "require": {
        "php": "^8.1",
        "magento/framework": ">=103.0.0",
        "magento/module-catalog": ">=104.0.0",
        "magento/module-cms": ">=104.0.0",
        "magento/module-store": ">=101.0.0",
        "magento/module-url-rewrite": ">=102.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Magneto\\CustomRedirect\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Magneto\\CustomRedirect\\Test\\": "Test/"
        }
    }
}
